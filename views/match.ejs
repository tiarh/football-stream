<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= match.home_team %> vs <%= match.away_team %> - Football Stream</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://vjs.zencdn.net/8.10.0/video-js.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .gradient-bg { background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%); }
    .live-pulse { animation: pulse 2s infinite; }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    .video-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: #000; border-radius: 12px; }
    .video-container iframe, .video-container video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
    .stream-card.active { border-color: #22c55e; background: rgba(34,197,94,0.1); }
  </style>
</head>
<body class="gradient-bg min-h-screen text-white">
  <!-- Header -->
  <header class="bg-slate-900/80 backdrop-blur-sm border-b border-slate-700 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4">
      <a href="/" class="text-slate-400 hover:text-white text-sm flex items-center gap-2 mb-3">
        ← Back to Matches
      </a>
      <div class="flex items-center justify-between">
        <div>
          <span class="text-xs text-slate-400"><%= match.league %></span>
          <h1 class="text-2xl font-bold mt-1"><%= match.home_team %> vs <%= match.away_team %></h1>
        </div>
        <% if (match.status === 'live') { %>
          <span class="bg-red-500 text-white px-3 py-1 rounded-full text-sm font-medium live-pulse">🔴 LIVE</span>
        <% } %>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-6xl mx-auto px-4 py-8">
    <!-- Video Player Section -->
    <div class="mb-8">
      <div class="bg-slate-800 rounded-xl p-4 border border-slate-700">
        <div id="player-container" class="video-container">
          <div class="flex items-center justify-center h-full text-slate-400">
            <div class="text-center">
              <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
              </svg>
              <p>Select a stream to start watching</p>
            </div>
          </div>
        </div>
        <div class="mt-4 text-center">
          <p class="text-sm text-slate-400">💡 Click on any stream below to load the player</p>
        </div>
      </div>
    </div>

    <!-- Match Info -->
    <div class="bg-slate-800 rounded-xl p-6 mb-6 border border-slate-700">
      <div class="flex items-center justify-between mb-4">
        <div class="text-center flex-1">
          <div class="w-16 h-16 bg-slate-700 rounded-full mx-auto mb-2 flex items-center justify-center text-2xl">🏠</div>
          <p class="font-bold text-lg"><%= match.home_team %></p>
        </div>
        <div class="px-6">
          <div class="text-3xl font-bold text-slate-500">VS</div>
          <p class="text-xs text-slate-400 mt-2 text-center">
            <%= new Date(match.match_date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
          </p>
        </div>
        <div class="text-center flex-1">
          <div class="w-16 h-16 bg-slate-700 rounded-full mx-auto mb-2 flex items-center justify-center text-2xl">✈️</div>
          <p class="font-bold text-lg"><%= match.away_team %></p>
        </div>
      </div>
      <% if (match.stadium) { %>
        <p class="text-center text-sm text-slate-400">📍 <%= match.stadium %></p>
      <% } %>
    </div>

    <!-- Streams List -->
    <section>
      <h2 class="text-xl font-bold mb-4">Available Streams (<%= streams.length %>)</h2>
      
      <% if (streams.length === 0) { %>
        <div class="bg-slate-800/50 rounded-xl p-8 text-center text-slate-400 border border-slate-700">
          <p class="text-lg mb-2">No streams available yet</p>
          <p class="text-sm">Check back closer to match time</p>
        </div>
      <% } else { %>
        <div class="grid md:grid-cols-2 gap-4">
          <% streams.forEach(function(stream, index) { %>
            <div class="stream-card bg-slate-800 rounded-xl p-4 border border-slate-700 hover:border-green-500 transition-all cursor-pointer" 
                 onclick="loadStream('<%= stream.stream_url %>', '<%= stream.type || 'embed' %>', this)">
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-3">
                  <span class="bg-green-500/20 text-green-400 px-2 py-1 rounded text-xs font-medium"><%= stream.quality %></span>
                  <span class="text-slate-400 text-sm"><%= stream.language %></span>
                  <span class="text-slate-300 font-medium"><%= stream.source_name %></span>
                </div>
                <div class="flex items-center gap-2 text-sm">
                  <span class="text-green-400">👍 <%= stream.votes_positive %></span>
                  <span class="text-red-400">👎 <%= stream.votes_negative %></span>
                </div>
              </div>
              
              <% if (stream.type === 'link') { %>
                <div class="flex items-center gap-2 text-xs text-orange-400 mb-2">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
                  </svg>
                  <span>Opens in new tab - <%= stream.note || 'Official source' %></span>
                </div>
              <% } else if (stream.type === 'hls' || stream.stream_url.includes('.m3u8')) { %>
                <div class="flex items-center gap-2 text-xs text-blue-400 mb-2">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
                  </svg>
                  <span>HLS Stream - Click to play</span>
                </div>
              <% } else { %>
                <div class="flex items-center gap-2 text-xs text-purple-400 mb-2">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"/>
                  </svg>
                  <span>Embedded Player</span>
                </div>
              <% } %>
              
              <div class="flex gap-2 mt-3">
                <button onclick="event.stopPropagation(); vote(<%= stream.id %>, 'positive')" class="flex-1 bg-slate-700 hover:bg-green-500/20 text-slate-300 hover:text-green-400 py-2 rounded-lg text-sm transition-colors">
                  👍 Working
                </button>
                <button onclick="event.stopPropagation(); vote(<%= stream.id %>, 'negative')" class="flex-1 bg-slate-700 hover:bg-red-500/20 text-slate-300 hover:text-red-400 py-2 rounded-lg text-sm transition-colors">
                  👎 Not Working
                </button>
                <button onclick="event.stopPropagation(); report(<%= stream.id %>)" class="px-4 bg-slate-700 hover:bg-red-500/20 text-slate-300 hover:text-red-400 py-2 rounded-lg text-sm transition-colors">
                  ⚠️
                </button>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>
  </main>

  <script src="https://vjs.zencdn.net/8.10.0/video.min.js"></script>
  <script>
    let player = null;

    function loadStream(url, type, element) {
      // Remove active class from all cards
      document.querySelectorAll('.stream-card').forEach(el => el.classList.remove('active'));
      element.classList.add('active');

      const container = document.getElementById('player-container');
      
      if (type === 'link') {
        // External link - open in new tab
        window.open(url, '_blank');
        container.innerHTML = '<div class="flex items-center justify-center h-full text-green-400"><div class="text-center"><svg class="w-16 h-16 mx-auto mb-4" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/><path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"/></svg><p>Opening stream in new tab...</p><p class="text-sm mt-2 text-slate-400">If nothing happens, <a href="' + url + '" target="_blank" class="underline">click here</a></p></div></div>';
      } else if (type === 'hls' || url.includes('.m3u8')) {
        // HLS stream with Video.js
        container.innerHTML = '<video id="video-player" class="video-js vjs-default-skin vjs-big-play-centered" controls preload="auto" width="100%" height="100%"></video>';
        player = videojs('video-player', {
          sources: [{ src: url, type: 'application/x-mpegURL' }]
        });
        player.play();
      } else {
        // YouTube/embed
        container.innerHTML = '<iframe src="' + url + '" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>';
      }
      
      // Scroll to player
      container.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    async function vote(streamId, type) {
      try {
        const res = await fetch('/api/vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ streamId, voteType: type })
        });
        if (res.ok) location.reload();
        else alert('Failed to vote');
      } catch (e) {
        alert('Failed to vote');
      }
    }

    async function report(streamId) {
      if (!confirm('Report this stream as not working?')) return;
      try {
        const res = await fetch('/api/report', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ streamId })
        });
        if (res.ok) location.reload();
        else alert('Failed to report');
      } catch (e) {
        alert('Failed to report');
      }
    }
  </script>
</body>
</html>
