<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Football Stream - Live & Upcoming</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .gradient-bg { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
    .live-pulse { animation: pulse 2s infinite; }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    .match-card:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(0,0,0,0.3); }
  </style>
</head>
<body class="gradient-bg min-h-screen text-white">
  <!-- Header -->
  <header class="border-b border-slate-700/50 bg-slate-900/50 backdrop-blur-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold bg-gradient-to-r from-blue-400 to-blue-600 bg-clip-text text-transparent">⚽ Football Stream</h1>
        <nav class="hidden md:flex gap-6">
          <a href="/" class="text-blue-400 font-medium">Home</a>
          <a href="/live" class="text-slate-400 hover:text-white transition-colors">Live Now</a>
          <a href="/upcoming" class="text-slate-400 hover:text-white transition-colors">Upcoming</a>
        </nav>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 py-8">
    <!-- LIVE NOW Section -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-3 h-3 bg-red-500 rounded-full live-pulse"></div>
        <h2 class="text-2xl font-bold">LIVE NOW</h2>
      </div>
      
      <% if (liveMatches && liveMatches.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% liveMatches.forEach(match => { %>
            <a href="/match/<%= match.id %>" class="match-card block bg-slate-800 rounded-xl p-4 border-2 border-red-500 hover:border-red-400 transition-all group">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs text-red-400 font-semibold flex items-center gap-1">
                  <span class="w-2 h-2 bg-red-500 rounded-full live-pulse"></span>
                  LIVE
                </span>
                <span class="text-xs text-slate-400"><%= match.league %></span>
              </div>
              <div class="space-y-2">
                <div class="flex items-center justify-between">
                  <span class="font-semibold group-hover:text-blue-400 transition-colors"><%= match.home_team %></span>
                  <span class="text-slate-400 text-sm">vs</span>
                  <span class="font-semibold group-hover:text-blue-400 transition-colors"><%= match.away_team %></span>
                </div>
              </div>
              <div class="mt-3 flex items-center justify-between">
                <span class="text-xs text-slate-400">Kickoff: Now</span>
                <span class="text-xs text-blue-400 font-medium">Watch →</span>
              </div>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <div class="bg-slate-800/50 rounded-xl p-8 text-center border border-slate-700">
          <p class="text-slate-400 text-lg">No matches live right now</p>
          <p class="text-slate-500 text-sm mt-2">Check back later for upcoming fixtures</p>
        </div>
      <% } %>
    </section>

    <!-- NEXT 7 DAYS Section -->
    <section>
      <div class="flex items-center gap-3 mb-6">
        <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
        <h2 class="text-2xl font-bold">NEXT 7 DAYS</h2>
      </div>
      
      <% if (upcomingMatches && upcomingMatches.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% upcomingMatches.forEach(match => { %>
            <% const homeOdds = polyOdds[match.home_team]; %>
            <% const awayOdds = polyOdds[match.away_team]; %>
            <a href="/match/<%= match.id %>" class="match-card block bg-slate-800 rounded-xl p-4 border border-slate-700 hover:border-blue-500 transition-all group">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs text-blue-400 font-medium"><%= match.league %></span>
                <% if (match.streams && match.streams.length > 0) { %>
                  <span class="text-xs text-green-400 flex items-center gap-1">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>
                    Streams Ready
                  </span>
                <% } else { %>
                  <span class="text-xs text-slate-500">No streams yet</span>
                <% } %>
              </div>
              <div class="space-y-2">
                <div class="flex items-center justify-between">
                  <span class="font-semibold group-hover:text-blue-400 transition-colors"><%= match.home_team %></span>
                  <span class="text-slate-400 text-sm">vs</span>
                  <span class="font-semibold group-hover:text-blue-400 transition-colors"><%= match.away_team %></span>
                </div>
                  <% if (homeOdds || awayOdds) { %>
                  <div class="flex items-center justify-between text-xs pt-1 border-t border-slate-700/50">
                    <span class="text-blue-300 font-mono"><%= homeOdds ? Math.round(parseFloat(homeOdds.yesPrice)*100) + '/100' : '—' %></span>
                    <span class="text-slate-500 text-[10px]">Odds</span>
                    <span class="text-orange-300 font-mono"><%= awayOdds ? Math.round(parseFloat(awayOdds.yesPrice)*100) + '/100' : '—' %></span>
                  </div>
                <% } %>
              </div>
              <div class="mt-3 flex items-center justify-between">
                <span class="text-xs text-slate-400">
                  <%= new Date(match.match_date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %>
                  <%= new Date(match.match_date).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                </span>
                <span class="text-xs text-blue-400 font-medium">Details →</span>
              </div>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <div class="bg-slate-800/50 rounded-xl p-8 text-center border border-slate-700">
          <p class="text-slate-400 text-lg">No upcoming fixtures in the next 7 days</p>
          <p class="text-slate-500 text-sm mt-2">Season break or no data available</p>
        </div>
      <% } %>
    </section>
  </main>

  <!-- WC 2026 Winner Odds -->
  <section class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <h2 class="text-xl font-bold">🏆 WC 2026 Winner Odds</h2>
      <span class="text-xs text-slate-500" id="odds-meta">Loading from Polymarket...</span>
    </div>
    <div class="bg-slate-800/60 rounded-xl border border-slate-700 p-4">
      <div id="odds-container" class="space-y-0">
        <div class="text-slate-500 text-sm animate-pulse">Fetching latest odds...</div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-slate-700/50 bg-slate-900/50 mt-12">
    <div class="max-w-7xl mx-auto px-4 py-6 text-center text-slate-400 text-sm">
      <p>⚽ Football Stream - WC 2026 + Top Leagues</p>
      <p class="mt-1">Streams available H-4 hours before kickoff</p>
      <p class="mt-1 text-blue-400/60 text-xs">Odds powered by Polymarket</p>
    </div>
  </footer>

  <script>
    // Auto-refresh every 60 seconds for live matches
    setTimeout(() => location.reload(), 60000);

    // Load WC 2026 winner odds from Polymarket
    async function loadOdds() {
      try {
        const res = await fetch('/api/odds');
        const data = await res.json();
        const container = document.getElementById('odds-container');
        if (!container || !data.odds) return;

        const top10 = Object.entries(data.odds).slice(0, 10);
        container.innerHTML = top10.map(([team, o]) => `
          <div class="flex items-center justify-between py-1.5">
            <span class="text-white font-medium text-sm">${team}</span>
            <div class="flex items-center gap-3">
              <span class="text-blue-400 text-xs font-mono">${o.impliedProb}</span>
              <span class="text-green-400 text-xs font-mono">${o.decimalOdds}x</span>
            </div>
          </div>
        `).join('');

        const meta = document.getElementById('odds-meta');
        if (meta && data.updatedAt) {
          meta.textContent = 'Odds via Polymarket · ' + new Date(data.updatedAt).toLocaleTimeString();
        }
      } catch (e) {
        console.error('Failed to load odds:', e);
      }
    }
    loadOdds();
    setInterval(loadOdds, 120000); // refresh every 2 min
  </script>
</body>
</html>
